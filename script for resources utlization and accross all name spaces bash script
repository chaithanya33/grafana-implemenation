#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
#  EKS Cluster Report  —  CEO-Ready · Accurate · Excel-Safe
#
#  FIXES vs previous version
#    ✔ NODE_MODE Dedicated/Shared — fixed bash [[ == ]] spacing bug
#    ✔ INSTANCE_TYPE — fixed go-template silently returning <no value>
#    ✔ REPLICAS — fixed awk field parsing on custom-columns output
#    ✔ TAINTS — fixed taint parsing and effect comparison
#    ✔ CSV — clean, Excel-safe, no date auto-format on replicas
#    ✔ Slow is fine — accuracy first
# ═══════════════════════════════════════════════════════════════════════════════

R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m'
C='\033[0;36m' M='\033[0;35m' B='\033[0;34m'
BOLD='\033[1m' DIM='\033[2m' RESET='\033[0m'

OUT_DIR="./eks_reports"
TS=$(date +"%Y%m%d_%H%M%S")
CSV="${OUT_DIR}/eks_${TS}.csv"
TXT="${OUT_DIR}/eks_${TS}.txt"

P="$$"
T_PODS="/tmp/_r_pods_${P}"
T_NODES="/tmp/_r_nodes_${P}"
T_RS="/tmp/_r_rs_${P}"
T_DEP="/tmp/_r_dep_${P}"
T_STS="/tmp/_r_sts_${P}"
T_JOB="/tmp/_r_job_${P}"
T_DS="/tmp/_r_ds_${P}"
T_RS_MAP="/tmp/_r_rsmap_${P}"
T_WL="/tmp/_r_wl_${P}"
T_NODE_WL="/tmp/_r_nodewl_${P}"

cleanup() { rm -f /tmp/_r_*_${P}; }
trap cleanup EXIT

hr()  { printf '%.0s─' {1..160}; echo; }
hr2() { printf '%.0s═' {1..160}; echo; }
log() { echo -e "${C}›${RESET} $*"; }
ok()  { echo -e "${G}✔${RESET} $*"; }
err() { echo -e "${R}✖ $*${RESET}" >&2; }

pad() {
  local raw="$1" w="$2"
  local clean; clean=$(printf '%b' "$raw" | sed 's/\x1b\[[0-9;]*m//g')
  local gap=$(( w - ${#clean} ))
  printf '%b' "$raw"
  [[ $gap -gt 0 ]] && printf '%*s' "$gap" ''
}

banner() {
  local ctx; ctx=$(kubectl config current-context 2>/dev/null || echo '?')
  echo
  echo -e "${BOLD}${C}"
  echo '  ███████╗██╗  ██╗███████╗    ██████╗ ███████╗██████╗  ██████╗ ██████╗ ████████╗'
  echo '  ██╔════╝██║ ██╔╝██╔════╝    ██╔══██╗██╔════╝██╔══██╗██╔═══██╗██╔══██╗╚══██╔══╝'
  echo '  █████╗  █████╔╝ ███████╗    ██████╔╝█████╗  ██████╔╝██║   ██║██████╔╝   ██║   '
  echo '  ██╔══╝  ██╔═██╗ ╚════██║    ██╔══██╗██╔══╝  ██╔═══╝ ██║   ██║██╔══██╗   ██║   '
  echo '  ███████╗██║  ██╗███████║    ██║  ██║███████╗██║     ╚██████╔╝██║  ██║   ██║   '
  echo '  ╚══════╝╚═╝  ╚═╝╚══════╝    ╚═╝  ╚═╝╚══════╝╚═╝      ╚═════╝ ╚═╝  ╚═╝   ╚═╝  '
  echo -e "${RESET}"
  echo -e "  ${BOLD}Context :${RESET} ${C}${ctx}${RESET}"
  echo -e "  ${BOLD}Time    :${RESET} $(date '+%Y-%m-%d %H:%M:%S')"
  echo
}

# ─────────────────────────────────────────────────────────────────────────────
preflight() {
  for cmd in kubectl awk sort; do
    command -v "$cmd" &>/dev/null || { err "'$cmd' not found"; exit 1; }
  done
  kubectl cluster-info &>/dev/null || {
    err "Cannot reach cluster. Run: aws eks update-kubeconfig --region <r> --name <n>"
    exit 1
  }
}

# ─────────────────────────────────────────────────────────────────────────────
fetch_all() {
  log "Fetching all cluster data (parallel)..."

  # Pods: tab-separated via jsonpath to avoid column alignment issues
  kubectl get pods -A -o json 2>/dev/null | \
    python3 -c "
import json,sys
data=json.load(sys.stdin)
for p in data['items']:
  ns=p['metadata']['namespace']
  name=p['metadata']['name']
  ors=p['metadata'].get('ownerReferences',[])
  okind=ors[0]['kind'] if ors else ''
  oname=ors[0]['name'] if ors else ''
  node=p['spec'].get('nodeName','')
  containers=p['spec'].get('containers',[{}])
  res=containers[0].get('resources',{}) if containers else {}
  req=res.get('requests',{})
  lim=res.get('limits',{})
  print('\t'.join([ns,name,okind,oname,node,
    req.get('cpu','-'),lim.get('cpu','-'),
    req.get('memory','-'),lim.get('memory','-')]))
" > "$T_PODS" &

  # Nodes: tab-separated via python for reliable field extraction
  # FIX: use jsonpath for instance-type label and parse taints properly
  kubectl get nodes -o json 2>/dev/null | \
    python3 -c "
import json,sys
data=json.load(sys.stdin)
for n in data['items']:
  name=n['metadata']['name']
  labels=n['metadata'].get('labels',{})
  itype=labels.get('node.kubernetes.io/instance-type',
        labels.get('beta.kubernetes.io/instance-type','unknown'))
  taints=n['spec'].get('taints',[])
  taint_strs=[]
  for t in taints:
    key=t.get('key','')
    val=t.get('value','')
    eff=t.get('effect','')
    taint_strs.append(f'{key}={val}:{eff}' if val else f'{key}:{eff}')
  taint_field=' '.join(taint_strs) if taint_strs else 'none'
  print('\t'.join([name,itype,taint_field]))
" > "$T_NODES" &

  # ReplicaSets: tab-separated via python
  kubectl get rs -A -o json 2>/dev/null | \
    python3 -c "
import json,sys
data=json.load(sys.stdin)
for r in data['items']:
  ns=r['metadata']['namespace']
  name=r['metadata']['name']
  ors=r['metadata'].get('ownerReferences',[])
  okind=ors[0]['kind'] if ors else ''
  oname=ors[0]['name'] if ors else ''
  desired=str(r['spec'].get('replicas') or 0)
  current=str((r['status'].get('replicas') or 0))
  ready=str((r['status'].get('readyReplicas') or 0))
  print('\t'.join([ns,name,okind,oname,desired,current,ready]))
" > "$T_RS" &

  # Deployments
  kubectl get deploy -A -o json 2>/dev/null | \
    python3 -c "
import json,sys
data=json.load(sys.stdin)
for d in data['items']:
  ns=d['metadata']['namespace']
  name=d['metadata']['name']
  desired=str(d['spec'].get('replicas') or 0)
  ready=str((d['status'].get('readyReplicas') or 0))
  print('\t'.join([ns,name,ready,desired]))
" > "$T_DEP" &

  # StatefulSets
  kubectl get sts -A -o json 2>/dev/null | \
    python3 -c "
import json,sys
data=json.load(sys.stdin)
for s in data['items']:
  ns=s['metadata']['namespace']
  name=s['metadata']['name']
  desired=str(s['spec'].get('replicas') or 1)
  ready=str((s['status'].get('readyReplicas') or 0))
  print('\t'.join([ns,name,ready,desired]))
" > "$T_STS" &

  # Jobs
  kubectl get jobs -A -o json 2>/dev/null | \
    python3 -c "
import json,sys
data=json.load(sys.stdin)
for j in data['items']:
  ns=j['metadata']['namespace']
  name=j['metadata']['name']
  desired=str(j['spec'].get('completions') or 1)
  succeeded=str((j['status'].get('succeeded') or 0))
  print('\t'.join([ns,name,desired,succeeded]))
" > "$T_JOB" &

  # DaemonSets
  kubectl get ds -A -o json 2>/dev/null | \
    python3 -c "
import json,sys
data=json.load(sys.stdin)
for d in data['items']:
  ns=d['metadata']['namespace']
  name=d['metadata']['name']
  desired=str(d['status'].get('desiredNumberScheduled') or 0)
  ready=str((d['status'].get('numberReady') or 0))
  print('\t'.join([ns,name,desired,ready]))
" > "$T_DS" &

  wait

  [[ -s "$T_PODS"  ]] || { err "No pods returned — check RBAC."; exit 1; }
  [[ -s "$T_NODES" ]] || { err "No nodes returned — check RBAC."; exit 1; }

  ok "Pods=$(wc -l <"$T_PODS"|tr -d ' ')  Nodes=$(wc -l <"$T_NODES"|tr -d ' ')  Deploys=$(wc -l <"$T_DEP"|tr -d ' ')  STS=$(wc -l <"$T_STS"|tr -d ' ')  Jobs=$(wc -l <"$T_JOB"|tr -d ' ')"
}

# ─────────────────────────────────────────────────────────────────────────────
build_rs_map() {
  # rs_map: key=NS/RS_NAME  →  type TAB owner_workload_name
  awk 'BEGIN{OFS="\t"; FS="\t"}{
    ns=$1; name=$2; okind=$3; oname=$4
    key=ns"/"name
    if(okind=="Deployment" && oname!="" && oname!="-")
      print key,"Deployment",oname
    else
      print key,"ReplicaSet",name
  }' "$T_RS" > "$T_RS_MAP"
}

# ─────────────────────────────────────────────────────────────────────────────
build_node_wl_map() {
  # node → workload map (DaemonSets excluded)
  awk -v rsmap="$T_RS_MAP" '
  BEGIN {
    FS="\t"
    while ((getline line < rsmap) > 0) {
      split(line,a,"\t"); rs_type[a[1]]=a[2]; rs_owner[a[1]]=a[3]
    }
  }
  {
    ns=$1;pod=$2;okind=$3;oname=$4;node=$5
    if(node==""||node=="-") next
    if(okind=="DaemonSet") next
    wname=""
    if(okind=="ReplicaSet" && oname!="" && oname!="-"){
      key=ns"/"oname
      wname=(key in rs_owner)?rs_owner[key]:oname
    } else if(okind=="" || okind=="-"){
      wname=pod
    } else {
      wname=(oname!=""&&oname!="-")?oname:pod
    }
    print node"\t"ns"/"wname
  }' "$T_PODS" | sort -u > "$T_NODE_WL"
}

# ─────────────────────────────────────────────────────────────────────────────
deduplicate_workloads() {
  log "Deduplicating pods into workload rows..."

  awk -v rsmap="$T_RS_MAP" '
  BEGIN {
    OFS="|"; FS="\t"
    while ((getline line < rsmap) > 0) {
      split(line,a,"\t"); rs_type[a[1]]=a[2]; rs_owner[a[1]]=a[3]
    }
  }
  {
    ns=$1;pod=$2;okind=$3;oname=$4;node=$5
    cpu_req=$6;cpu_lim=$7;mem_req=$8;mem_lim=$9

    wtype=""; wname=""
    if(okind=="ReplicaSet" && oname!="" && oname!="-"){
      key=ns"/"oname
      wtype=(key in rs_type)?rs_type[key]:"ReplicaSet"
      wname=(key in rs_owner)?rs_owner[key]:oname
    } else if(okind==""||okind=="-"){
      wtype="Standalone"; wname=pod
    } else {
      wtype=okind
      wname=(oname!=""&&oname!="-")?oname:pod
    }

    dk=ns"__"wname
    if(dk in seen) next
    seen[dk]=1

    if(cpu_req==""||cpu_req=="-") cpu_req="-"
    if(cpu_lim==""||cpu_lim=="-") cpu_lim="-"
    if(mem_req==""||mem_req=="-") mem_req="-"
    if(mem_lim==""||mem_lim=="-") mem_lim="-"
    if(node==""||node=="-") node="<pending>"

    print ns,wname,wtype,cpu_req,cpu_lim,mem_req,mem_lim,node
  }' "$T_PODS" | sort -t'|' -k1,1 -k3,3 -k2,2 > "$T_WL"

  ok "Unique workloads: $(wc -l <"$T_WL"|tr -d ' ')"
}

# ─────────────────────────────────────────────────────────────────────────────
# FIX: awk uses FS="\t" so fields parse correctly
get_replicas() {
  local ns="$1" name="$2" wtype="$3"
  local r="" d=""
  case "$wtype" in
    Deployment)
      r=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $3; exit}' "$T_DEP")
      d=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $4; exit}' "$T_DEP") ;;
    StatefulSet)
      r=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $3; exit}' "$T_STS")
      d=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $4; exit}' "$T_STS") ;;
    ReplicaSet)
      r=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $7; exit}' "$T_RS")
      d=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $5; exit}' "$T_RS") ;;
    DaemonSet)
      r=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $4; exit}' "$T_DS")
      d=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $3; exit}' "$T_DS") ;;
    Job)
      r=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $4; exit}' "$T_JOB")
      d=$(awk -F'\t' -v n="$ns" -v w="$name" '$1==n && $2==w {print $3; exit}' "$T_JOB") ;;
  esac

  # Fallback: count pods whose name starts with workload name
  if [[ -z "$r" || "$r" == "-" || "$r" == "0" ]]; then
    r=$(awk -F'\t' -v n="$ns" -v w="$name" '
      $1==n { nm=$2; if(nm==w || index(nm,w"-")==1 || index(nm,w".")==1) c++ }
      END { print (c>0)?c:0 }
    ' "$T_PODS")
  fi
  [[ -z "$r" || "$r" == "-" ]] && r="0"
  [[ -z "$d" || "$d" == "-" ]] && d="?"
  # Use " of " instead of "/" — slash like "1/1" gets auto-converted to Jan 1 by Excel
  echo "${r} of ${d}"
}

# ─────────────────────────────────────────────────────────────────────────────
# FIX: taint comparison uses proper bash == with spaces, and handles multi-node
# Returns:  MODE|NODE_NAME|ITYPE|TAINTS
node_info() {
  local ns="$1" wname="$2" sample_node="$3"
  local key="${ns}/${wname}"

  # All nodes this workload runs on
  local nodes
  nodes=$(awk -F'\t' -v k="$key" '$2==k {print $1}' "$T_NODE_WL" | sort -u)
  [[ -z "$nodes" ]] && nodes="$sample_node"

  local first_node=""

  while IFS= read -r node; do
    [[ -z "$node" || "$node" == "-" || "$node" == "<pending>" ]] && continue
    [[ -z "$first_node" ]] && first_node="$node"

    local itype taints_raw
    itype=$(awk -F'\t' -v n="$node" '$1==n {print $2; exit}' "$T_NODES")
    taints_raw=$(awk -F'\t' -v n="$node" '$1==n {print $3; exit}' "$T_NODES")

    [[ -z "$itype" || "$itype" == "-" ]] && itype="unknown"
    [[ -z "$taints_raw" ]] && taints_raw="none"

    # FIX: proper bash string comparison with spaces around ==
    if [[ "$taints_raw" != "none" ]]; then
      # Check if any taint has NoSchedule or NoExecute effect
      local has_restricting_taint=0
      for taint in $taints_raw; do
        local eff="${taint##*:}"
        if [[ "$eff" == "NoSchedule" ]] || [[ "$eff" == "NoExecute" ]]; then
          has_restricting_taint=1
          break
        fi
      done
      if [[ $has_restricting_taint -eq 1 ]]; then
        echo "Dedicated|${node}|${itype}|${taints_raw}"
        return
      fi
    fi

    # Single workload on node → dedicated
    local wl_count
    wl_count=$(awk -F'\t' -v n="$node" '$1==n {print $2}' "$T_NODE_WL" | sort -u | wc -l | tr -d ' ')
    if [[ "$wl_count" -eq 1 ]]; then
      echo "Dedicated|${node}|${itype}|${taints_raw}"
      return
    fi

  done <<< "$nodes"

  # Shared — use first node found (or sample)
  local use_node="${first_node:-${sample_node}}"
  [[ -z "$use_node" || "$use_node" == "-" ]] && use_node="unknown"

  local itype taints_raw
  itype=$(awk -F'\t' -v n="$use_node" '$1==n {print $2; exit}' "$T_NODES")
  taints_raw=$(awk -F'\t' -v n="$use_node" '$1==n {print $3; exit}' "$T_NODES")
  [[ -z "$itype" || "$itype" == "-" ]] && itype="unknown"
  [[ -z "$taints_raw" ]] && taints_raw="none"

  echo "Shared|${use_node}|${itype}|${taints_raw}"
}

# ─────────────────────────────────────────────────────────────────────────────
c_type() {
  case "$1" in
    Deployment)  echo -e "${B}Deployment${RESET}"   ;;
    StatefulSet) echo -e "${M}StatefulSet${RESET}"  ;;
    DaemonSet)   echo -e "${Y}DaemonSet${RESET}"    ;;
    Job|CronJob) echo -e "${C}${1}${RESET}"         ;;
    ReplicaSet)  echo -e "${DIM}ReplicaSet${RESET}" ;;
    *)           echo "$1"                           ;;
  esac
}
c_rep() {
  # Format is "R of D"
  local r d
  r=$(echo "$1" | awk '{print $1}')
  d=$(echo "$1" | awk '{print $3}')
  if   [[ "$d" == "?" ]];   then echo -e "${C}${1}${RESET}"
  elif [[ "$r" == "$d" ]];  then echo -e "${G}${1}${RESET}"
  else                           echo -e "${R}${1}${RESET}"
  fi
}
c_mode() {
  if [[ "$1" == "Dedicated" ]]; then
    echo -e "${G}Dedicated${RESET}"
  else
    echo -e "${Y}Shared${RESET}"
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
report_workloads() {
  mkdir -p "$OUT_DIR"
  local ctx; ctx=$(kubectl config current-context 2>/dev/null || echo unknown)
  { echo "EKS CLUSTER REPORT"; echo "Context : ${ctx}"; echo "Generated : $(date)"; echo ""; } > "$TXT"

  # CSV header
  printf '%s\n' "NAMESPACE,WORKLOAD,TYPE,REPLICAS,NODE_MODE,NODE_NAME,INSTANCE_TYPE,TAINTS,CPU_REQ,CPU_LIM,MEM_REQ,MEM_LIM" > "$CSV"

  local C1=30 C2=50 C3=13 C4=8 C5=11 C6=48 C7=17 C8=35 C9=9 C10=9 C11=9 C12=9

  echo ""; echo -e "${BOLD}${C}"; hr2
  echo -e "  WORKLOAD REPORT  —  ${ctx}"; hr2; echo -e "${RESET}"

  printf "${BOLD}"
  pad "NAMESPACE"     $C1; printf ' '
  pad "WORKLOAD"      $C2; printf ' '
  pad "TYPE"          $C3; printf ' '
  pad "REPLICAS"      $C4; printf ' '
  pad "NODE MODE"     $C5; printf ' '
  pad "NODE NAME"     $C6; printf ' '
  pad "INSTANCE TYPE" $C7; printf ' '
  pad "TAINTS"        $C8; printf ' '
  printf "%-${C9}s %-${C10}s %-${C11}s %-${C12}s\n" "CPU_REQ" "CPU_LIM" "MEM_REQ" "MEM_LIM"
  printf "${RESET}"
  echo -e "${BOLD}$(hr)${RESET}"

  {
    printf "%-${C1}s %-${C2}s %-${C3}s %-${C4}s %-${C5}s %-${C6}s %-${C7}s %-${C8}s %-${C9}s %-${C10}s %-${C11}s %-${C12}s\n" \
      NAMESPACE WORKLOAD TYPE REPLICAS NODE_MODE NODE_NAME INSTANCE_TYPE TAINTS CPU_REQ CPU_LIM MEM_REQ MEM_LIM
    hr
  } >> "$TXT"

  local TOTAL=0 DEDICATED=0 SHARED=0 PREV_NS=""

  while IFS='|' read -r NS WNAME WTYPE CPU_REQ CPU_LIM MEM_REQ MEM_LIM SNODE; do
    [[ -z "$NS" ]] && continue
    TOTAL=$(( TOTAL + 1 ))

    [[ "$NS" != "$PREV_NS" && -n "$PREV_NS" ]] && \
      echo -e "${DIM}$(printf '%.0s·' {1..160})${RESET}"
    PREV_NS="$NS"

    local REP INFO MODE NODE_NAME ITYPE TAINTS
    REP=$(get_replicas "$NS" "$WNAME" "$WTYPE")
    INFO=$(node_info   "$NS" "$WNAME" "$SNODE")
    MODE=$(     cut -d'|' -f1 <<< "$INFO")
    NODE_NAME=$(cut -d'|' -f2 <<< "$INFO")
    ITYPE=$(    cut -d'|' -f3 <<< "$INFO")
    TAINTS=$(   cut -d'|' -f4 <<< "$INFO")

    [[ -z "$NODE_NAME" || "$NODE_NAME" == "-" || "$NODE_NAME" == "<none>" ]] && \
      NODE_NAME="${SNODE:-unknown}"
    [[ -z "$MODE" ]] && MODE="Shared"

    if [[ "$MODE" == "Dedicated" ]]; then
      DEDICATED=$(( DEDICATED + 1 ))
    else
      SHARED=$(( SHARED + 1 ))
    fi

    # Terminal output
    pad "$NS"                        $C1; printf ' '
    pad "$WNAME"                     $C2; printf ' '
    pad "$(c_type "$WTYPE")"         $C3; printf ' '
    pad "$(c_rep  "$REP")"           $C4; printf ' '
    pad "$(c_mode "$MODE")"          $C5; printf ' '
    pad "${DIM}${NODE_NAME}${RESET}" $C6; printf ' '
    pad "${C}${ITYPE}${RESET}"       $C7; printf ' '
    pad "${Y}${TAINTS}${RESET}"      $C8; printf ' '
    printf "%-${C9}s %-${C10}s %-${C11}s %-${C12}s\n" \
      "$CPU_REQ" "$CPU_LIM" "$MEM_REQ" "$MEM_LIM"

    # TXT plain
    printf "%-${C1}s %-${C2}s %-${C3}s %-${C4}s %-${C5}s %-${C6}s %-${C7}s %-${C8}s %-${C9}s %-${C10}s %-${C11}s %-${C12}s\n" \
      "$NS" "$WNAME" "$WTYPE" "$REP" "$MODE" "$NODE_NAME" "$ITYPE" "$TAINTS" \
      "$CPU_REQ" "$CPU_LIM" "$MEM_REQ" "$MEM_LIM" >> "$TXT"

    # CSV — all fields quoted as text; REPLICAS uses "X of Y" format (no slash = no Excel date conversion)
    local TC; TC="${TAINTS// /; }"
    TC="${TC//,/;}"
    printf '%s\n' "\"${NS}\",\"${WNAME}\",\"${WTYPE}\",\"${REP}\",\"${MODE}\",\"${NODE_NAME}\",\"${ITYPE}\",\"${TC}\",\"${CPU_REQ}\",\"${CPU_LIM}\",\"${MEM_REQ}\",\"${MEM_LIM}\"" >> "$CSV"

  done < "$T_WL"

  echo -e "${BOLD}$(hr)${RESET}"
  echo -e "  Total: ${BOLD}${TOTAL}${RESET}  │  ${G}Dedicated: ${DEDICATED}${RESET}  │  ${Y}Shared: ${SHARED}${RESET}"
  { hr; echo "  Total: ${TOTAL}  |  Dedicated: ${DEDICATED}  |  Shared: ${SHARED}"; } >> "$TXT"
}

# ─────────────────────────────────────────────────────────────────────────────
report_nodes() {
  echo ""; echo -e "${BOLD}${C}"; hr2; echo -e "  NODE DETAILS"; hr2; echo -e "${RESET}"
  local NC=48 NI=17 NC2=10 NM=14 NT=55
  printf "${BOLD}%-${NC}s %-${NI}s %-${NC2}s %-${NM}s %-${NT}s${RESET}\n" \
    "NODE NAME" "INSTANCE TYPE" "CPU ALLOC" "MEM ALLOC" "TAINTS"
  hr
  { printf "%-${NC}s %-${NI}s %-${NC2}s %-${NM}s %-${NT}s\n" \
      "NODE NAME" "INSTANCE TYPE" "CPU ALLOC" "MEM ALLOC" "TAINTS"; hr; } >> "$TXT"

  kubectl get nodes -o json 2>/dev/null | \
    python3 -c "
import json,sys
data=json.load(sys.stdin)
for n in data['items']:
  name=n['metadata']['name']
  labels=n['metadata'].get('labels',{})
  itype=labels.get('node.kubernetes.io/instance-type',
        labels.get('beta.kubernetes.io/instance-type','unknown'))
  alloc=n['status'].get('allocatable',{})
  cpu=alloc.get('cpu','?')
  mem=alloc.get('memory','?')
  conds=n['status'].get('conditions',[])
  status='Unknown'
  for c in conds:
    if c.get('type')=='Ready':
      status='Ready' if c.get('status')=='True' else 'NotReady'
  print('\t'.join([name,itype,cpu,mem,status]))
" | while IFS=$'\t' read -r NNAME ITYPE NCPU NMEM NSTATUS; do
      [[ -z "$NNAME" ]] && continue
      local RT
      RT=$(awk -F'\t' -v n="$NNAME" '$1==n {print $3; exit}' "$T_NODES")
      [[ -z "$RT" ]] && RT="none"
      local SC; [[ "$NSTATUS" == "Ready" ]] && SC="${G}" || SC="${R}"
      pad "${SC}${NNAME}${RESET}" $NC; printf ' '
      pad "${C}${ITYPE}${RESET}"  $NI; printf ' '
      printf "%-${NC2}s %-${NM}s " "$NCPU" "$NMEM"
      echo -e "${Y}${RT}${RESET}"
      printf "%-${NC}s %-${NI}s %-${NC2}s %-${NM}s %-${NT}s\n" \
        "$NNAME" "$ITYPE" "$NCPU" "$NMEM" "$RT" >> "$TXT"
    done
  echo ""
}

# ─────────────────────────────────────────────────────────────────────────────
report_namespaces() {
  echo ""; echo -e "${BOLD}${C}"; hr2; echo -e "  NAMESPACE SUMMARY"; hr2; echo -e "${RESET}"
  printf "${BOLD}%-34s %8s %10s %10s %8s %8s${RESET}\n" \
    "NAMESPACE" "PODS" "DEPLOYS" "STS" "RS" "JOBS"
  hr
  kubectl get namespaces --no-headers \
    -o custom-columns='NAME:.metadata.name' 2>/dev/null | while read -r NS; do
      local PODS DEPS STS RS JOBS
      PODS=$(awk -F'\t' -v n="$NS" '$1==n' "$T_PODS" | wc -l | tr -d ' ')
      DEPS=$(awk -F'\t' -v n="$NS" '$1==n' "$T_DEP"  | wc -l | tr -d ' ')
      STS=$( awk -F'\t' -v n="$NS" '$1==n' "$T_STS"  | wc -l | tr -d ' ')
      RS=$(  awk -F'\t' -v n="$NS" '$1==n' "$T_RS"   | wc -l | tr -d ' ')
      JOBS=$(awk -F'\t' -v n="$NS" '$1==n' "$T_JOB"  | wc -l | tr -d ' ')
      (( PODS+DEPS+STS+RS+JOBS > 0 )) || continue
      printf "%-34s %8s %10s %10s %8s %8s\n" "$NS" "$PODS" "$DEPS" "$STS" "$RS" "$JOBS"
    done
  echo ""
}

# ─────────────────────────────────────────────────────────────────────────────
footer() {
  echo ""; echo -e "${BOLD}${G}"; hr2; echo -e "  ✔  REPORT COMPLETE"; hr2; echo -e "${RESET}"
  echo -e "  ${BOLD}📄 Text :${RESET} ${C}${TXT}${RESET}"
  echo -e "  ${BOLD}📊 CSV  :${RESET} ${C}${CSV}${RESET}"
  echo -e "  ${DIM}  Note: REPLICAS shown as \"X of Y\" — prevents Excel date auto-format${RESET}"
  echo ""
}

# ─────────────────────────────────────────────────────────────────────────────
main() {
  banner
  preflight
  fetch_all
  build_rs_map
  build_node_wl_map
  deduplicate_workloads
  report_nodes
  report_workloads
  report_namespaces
  footer
}

main "$@"
